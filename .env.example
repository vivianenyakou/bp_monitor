# Application
APP_NAME=BP Monitor
APP_VERSION=1.0.0
APP_MODE=standalone
DEBUG=false

# Base de données
POSTGRES_USER=
POSTGRES_PASSWORD=
POSTGRES_DB=
# Encode special characters in DATABASE_URL passwords, e.g. @ -> %40.
DATABASE_URL=postgresql+asyncpg://user:password@db:5432/bp_monitor

# Redis
REDIS_URL=redis://redis:6379/0

# JWT
JWT_SECRET_KEY=
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=60
JWT_REFRESH_TOKEN_EXPIRE_DAYS=7

# Notifications
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_FROM_NUMBER=
FCM_SERVER_KEY=
