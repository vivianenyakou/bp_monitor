# Application
APP_NAME=BP Monitor
APP_VERSION=1.0.0
APP_MODE=standalone
DEBUG=false

# Base de données
DATABASE_URL=postgresql+asyncpg://user:password@localhost:5432/bp_monitor

# Redis
REDIS_URL=redis://localhost:6379/0

# JWT
JWT_SECRET_KEY=change-me-in-production
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=60

# Notifications
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_FROM_NUMBER=
FCM_SERVER_KEY=

# Mode intégré Vitoo Santé (optionnel)
VITOO_API_URL=
VITOO_API_KEY=s